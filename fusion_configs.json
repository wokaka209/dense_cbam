{
    "description": "图像融合配置文件 - 包含融合引擎的所有配置参数",
    "version": "1.0",
    "author": "wokaka209",
    "date": "2026-03-31",

    "io_paths": {
        "single_mode": {
            "ir_image": "",
            "vi_image": "",
            "output": "data_result/fusion_optimized"
        },
        "batch_mode": {
            "ir_dir": "E:/whx_Graduation project/baseline_project/dataset/ir",
            "vi_dir": "E:/whx_Graduation project/baseline_project/dataset/vi",
            "output_dir": "data_result/fusion_optimized"
        }
    },

    "model": {
        "model_path": "./runs/stage2_cbam/checkpoints/best.pth",
        "model_name": "DenseFuse",
        "input_channels": 3,
        "output_channels": 3,
        "gray_mode": false,
        "target_size": [768, 1024],
        "use_attention": true,
        "use_fusion_layer": false,
        "strategy_name": "hybrid",
        "fusion_weight": 0.5,
        "description": {
            "use_fusion_layer": "是否使用融合层（阶段三为true，阶段二为false）",
            "strategy_name": "特征融合策略名称（weighted_average, l1_norm, hybrid）",
            "fusion_weight": "加权平均融合的权重（仅strategy_name=weighted_average时有效）"
        }
    },

    "device": {
        "type": "cuda",
        "available_options": ["cuda", "cpu"]
    },

    "performance": {
        "batch_size": 1,
        "recommended_batch_range": [4, 8],
        "show_stats": true,
        "num_workers": 0,
        "enable_cuda_optimize": true,
        "enable_mixed_precision": false
    },

    "fusion_strategies": {
        "available": [
            "weighted_average",
            "l1_norm",
            "hybrid"
        ],
        "default": "hybrid",
        "description": {
            "weighted_average": "加权平均融合策略 - 简单快速，适合实时应用",
            "l1_norm": "L1范数自适应融合 - 根据特征强度自适应调整权重",
            "hybrid": "混合融合策略 - 结合增强L1和多尺度融合的优势，效果最佳"
        },
        "performance": {
            "weighted_average": {
                "speed": "最快",
                "quality": "中等",
                "memory": "最低"
            },
            "l1_norm": {
                "speed": "快",
                "quality": "良好",
                "memory": "中等"
            },
            "hybrid": {
                "speed": "中等",
                "quality": "最佳",
                "memory": "较高"
            }
        },
        "recommendations": {
            "real_time": "weighted_average",
            "balanced": "l1_norm",
            "high_quality": "hybrid"
        }
    },

    "image_preprocessing": {
        "resize": {
            "enabled": true,
            "target_size": [768, 1024]
        },
        "normalize": {
            "enabled": true,
            "mean": [0.5, 0.5, 0.5],
            "std": [0.5, 0.5, 0.5]
        },
        "to_tensor": true
    },

    "image_postprocessing": {
        "denormalize": true,
        "clamp_range": [0, 1],
        "restore_original_size": true
    },

    "optimization": {
        "memory": {
            "preallocate_tensors": true,
            "cache_images": false,
            "empty_cache": true
        },
        "cuda": {
            "enable_memory_optimization": true,
            "enable_async_execution": false,
            "mixed_precision": false
        },
        "io": {
            "parallel_loading": true,
            "async_saving": false
        }
    },

    "performance_monitoring": {
        "track_fps": true,
        "track_memory": true,
        "track_throughput": true,
        "log_interval": 10
    }
}
